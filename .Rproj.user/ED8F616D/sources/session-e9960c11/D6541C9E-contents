   "source": [
    "# =========================================================\n",
    "# Random Forest + XGBoost prediction workflow\n",
    "# Two clearly separated pipelines:\n",
    "#\n",
    "#   PIPELINE A: ALL ELIGIBLE VARIABLES\n",
    "#   PIPELINE B: ONLY STABILITY-SELECTED VARIABLES\n",
    "#\n",
    "# Inputs:\n",
    "#   00_data/01_processed/03_imputation/df_train_imputed.rds\n",
    "#   00_data/01_processed/03_imputation/df_test_imputed.rds\n",
    "#   00_data/02_analysis/stability_selection_sharp_wo_sbp_FINAL/selected_variable_names.txt\n",
    "#\n",
    "# Outputs:\n",
    "#   - AUC table\n",
    "#   - ROC comparison plots\n",
    "#   - feature importance plots\n",
    "#   - fitted models + predictions + metrics\n",
    "# =========================================================\n",
    "\n",
    "import os\n",
    "import json\n",
    "import warnings\n",
    "from pathlib import Path\n",
    "\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "from sklearn.compose import ColumnTransformer\n",
    "from sklearn.pipeline import Pipeline\n",
    "from sklearn.impute import SimpleImputer\n",
    "from sklearn.preprocessing import OneHotEncoder\n",
    "from sklearn.metrics import (\n",
    "    roc_auc_score,\n",
    "    roc_curve,\n",
    "    confusion_matrix,\n",
    "    ConfusionMatrixDisplay,\n",
    "    accuracy_score,\n",
    "    precision_score,\n",
    "    recall_score,\n",
    "    f1_score,\n",
    ")\n",
    "from sklearn.model_selection import GridSearchCV\n",
    "from sklearn.inspection import permutation_importance\n",
    "from sklearn.ensemble import RandomForestClassifier\n",
    "\n",
    "from xgboost import XGBClassifier\n",
    "\n",
    "# pyreadr is needed to read .rds files from Python\n",
    "import pyreadr\n",
    "\n",
    "\n",
    "warnings.filterwarnings(\"ignore\", category=UserWarning)\n",
    "warnings.filterwarnings(\"ignore\", category=FutureWarning)\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# 0) Paths\n",
    "# ---------------------------------------------------------\n",
    "BASE_DIR = Path(\".\")\n",
    "\n",
    "TRAIN_RDS = BASE_DIR / \"00_data\" / \"01_processed\" / \"03_imputation\" / \"df_train_imputed.rds\"\n",
    "TEST_RDS  = BASE_DIR / \"00_data\" / \"01_processed\" / \"03_imputation\" / \"df_test_imputed.rds\"\n",
    "\n",
    "SEL_DIR = BASE_DIR / \"00_data\" / \"02_analysis\" / \"stability_selection_sharp_wo_sbp_FINAL\"\n",
    "SEL_TXT = SEL_DIR / \"selected_variable_names.txt\"\n",
    "\n",
    "OUT_DIR = BASE_DIR / \"00_data\" / \"02_analysis\" / \"tree_models_python\"\n",
    "OUT_DIR.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "RANDOM_STATE = 42\n",
    "N_JOBS = -1\n",
    "TARGET = \"has_cvd\"\n",
    "\n",
    "# Variables excluded from predictive models due to ID / leakage / post-outcome timing\n",
    "EXCLUDE_VARS = {\n",
    "    \"eid\",\n",
    "    \"has_cvd\",\n",
    "    \"first_cvd_date\",\n",
    "    \"death_date\",\n",
    "}\n",
    "\n",
    "# Optional exclusion of recruitment_date\n",
    "EXCLUDE_RECRUITMENT_DATE = True\n",
    "if EXCLUDE_RECRUITMENT_DATE:\n",
    "    EXCLUDE_VARS.add(\"recruitment_date\")\n",
    "\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# 1) Helpers\n",
    "# ---------------------------------------------------------\n",
    "def read_rds_dataframe(path: Path) -> pd.DataFrame:\n",
    "    \"\"\"Read a single-object .rds file into a pandas DataFrame.\"\"\"\n",
    "    result = pyreadr.read_r(str(path))\n",
    "    if len(result.keys()) == 0:\n",
    "        raise ValueError(f\"No object found inside {path}\")\n",
    "    df = next(iter(result.values()))\n",
    "    if not isinstance(df, pd.DataFrame):\n",
    "        raise TypeError(f\"Object inside {path} is not a DataFrame\")\n",
    "    return df\n",
    "\n",
    "\n",
    "def load_selected_variables(txt_path: Path) -> list[str]:\n",
    "    \"\"\"Read selected variable names from TXT only.\"\"\"\n",
    "    if not txt_path.exists():\n",
    "        raise FileNotFoundError(f\"Selected-variable TXT file not found: {txt_path}\")\n",
    "\n",
    "    with open(txt_path, \"r\", encoding=\"utf-8\") as f:\n",
    "        lines = [line.strip() for line in f.readlines()]\n",
    "\n",
    "    selected = [x for x in lines if x]\n",
    "    selected = list(dict.fromkeys(selected))\n",
    "    return selected\n",
    "\n",
    "\n",
    "def clean_target(y: pd.Series) -> pd.Series:\n",
    "    \"\"\"Ensure binary 0/1 integer target.\"\"\"\n",
    "    if pd.api.types.is_bool_dtype(y):\n",
    "        return y.astype(int)\n",
    "\n",
    "    if pd.api.types.is_numeric_dtype(y):\n",
    "        vals = set(pd.Series(y).dropna().unique().tolist())\n",
    "        if vals.issubset({0, 1}):\n",
    "            return y.astype(int)\n",
    "\n",
    "    y_str = y.astype(str).str.strip().str.lower()\n",
    "    mapping = {\n",
    "        \"0\": 0, \"1\": 1,\n",
    "        \"false\": 0, \"true\": 1,\n",
    "        \"no\": 0, \"yes\": 1,\n",
    "    }\n",
    "    y_mapped = y_str.map(mapping)\n",
    "    if y_mapped.isna().any():\n",
    "        bad = y[y_mapped.isna()].unique()\n",
    "        raise ValueError(f\"Target contains values that cannot be mapped to binary 0/1: {bad}\")\n",
    "    return y_mapped.astype(int)\n",
    "\n",
    "\n",
    "def infer_feature_types(X: pd.DataFrame):\n",
    "    \"\"\"\n",
    "    Separate numeric vs categorical columns.\n",
    "    Dates are converted to numeric days since epoch.\n",
    "    \"\"\"\n",
    "    X = X.copy()\n",
    "\n",
    "    dt_cols = X.select_dtypes(include=[\"datetime64[ns]\", \"datetime64[ns, UTC]\"]).columns.tolist()\n",
    "    for col in dt_cols:\n",
    "        X[col] = pd.to_datetime(X[col], errors=\"coerce\")\n",
    "        X[col] = (X[col] - pd.Timestamp(\"1970-01-01\")) / pd.Timedelta(days=1)\n",
    "\n",
    "    numeric_cols = X.select_dtypes(include=[\"number\", \"bool\"]).columns.tolist()\n",
    "    categorical_cols = [c for c in X.columns if c not in numeric_cols]\n",
    "\n",
    "    return X, numeric_cols, categorical_cols\n",
    "\n",
    "\n",
    "def make_preprocessor(X: pd.DataFrame):\n",
    "    \"\"\"\n",
    "    Build preprocessing pipeline:\n",
    "      - numeric: median impute\n",
    "      - categorical: most-frequent impute + one-hot encode\n",
    "    \"\"\"\n",
    "    X2, numeric_cols, categorical_cols = infer_feature_types(X)\n",
    "\n",
    "    numeric_transformer = Pipeline(\n",
    "        steps=[\n",
    "            (\"imputer\", SimpleImputer(strategy=\"median\")),\n",
    "        ]\n",
    "    )\n",
    "\n",
    "    categorical_transformer = Pipeline(\n",
    "        steps=[\n",
    "            (\"imputer\", SimpleImputer(strategy=\"most_frequent\")),\n",
    "            (\"onehot\", OneHotEncoder(handle_unknown=\"ignore\")),\n",
    "        ]\n",
    "    )\n",
    "\n",
    "    preprocessor = ColumnTransformer(\n",
    "        transformers=[\n",
    "            (\"num\", numeric_transformer, numeric_cols),\n",
    "            (\"cat\", categorical_transformer, categorical_cols),\n",
    "        ],\n",
    "        remainder=\"drop\",\n",
    "    )\n",
    "\n",
    "    return X2, preprocessor, numeric_cols, categorical_cols\n",
    "\n",
    "\n",
    "def evaluate_classifier(model, X_test, y_test):\n",
    "    \"\"\"Return metrics + ROC curve data.\"\"\"\n",
    "    y_pred = model.predict(X_test)\n",
    "    y_prob = model.predict_proba(X_test)[:, 1]\n",
    "\n",
    "    auc = roc_auc_score(y_test, y_prob)\n",
    "    fpr, tpr, thresholds = roc_curve(y_test, y_prob)\n",
    "\n",
    "    return {\n",
    "        \"auc\": auc,\n",
    "        \"accuracy\": accuracy_score(y_test, y_pred),\n",
    "        \"precision\": precision_score(y_test, y_pred, zero_division=0),\n",
    "        \"recall\": recall_score(y_test, y_pred, zero_division=0),\n",
    "        \"f1\": f1_score(y_test, y_pred, zero_division=0),\n",
    "        \"fpr\": fpr,\n",
    "        \"tpr\": tpr,\n",
    "        \"thresholds\": thresholds,\n",
    "        \"y_pred\": y_pred,\n",
    "        \"y_prob\": y_prob,\n",
    "    }\n",
    "\n",
    "\n",
    "def get_feature_names_from_pipeline(fitted_pipeline, numeric_cols, categorical_cols):\n",
    "    \"\"\"Recover transformed feature names after preprocessing.\"\"\"\n",
    "    preprocessor = fitted_pipeline.named_steps[\"preprocessor\"]\n",
    "\n",
    "    feature_names = []\n",
    "\n",
    "    if numeric_cols:\n",
    "        feature_names.extend(numeric_cols)\n",
    "\n",
    "    if categorical_cols:\n",
    "        ohe = preprocessor.named_transformers_[\"cat\"].named_steps[\"onehot\"]\n",
    "        cat_names = ohe.get_feature_names_out(categorical_cols).tolist()\n",
    "        feature_names.extend(cat_names)\n",
    "\n",
    "    return feature_names\n",
    "\n",
    "\n",
    "def plot_confusion_matrix(y_true, y_pred, title, out_path):\n",
    "    cm = confusion_matrix(y_true, y_pred)\n",
    "    fig, ax = plt.subplots(figsize=(5, 5))\n",
    "    ConfusionMatrixDisplay(\n",
    "        confusion_matrix=cm,\n",
    "        display_labels=[\"no_cvd\", \"cvd\"],\n",
    "    ).plot(cmap=\"Blues\", colorbar=False, ax=ax)\n",
    "    ax.set_title(title)\n",
    "    plt.tight_layout()\n",
    "    plt.savefig(out_path, dpi=300, bbox_inches=\"tight\")\n",
    "    plt.close()\n",
    "\n",
    "\n",
    "def plot_top_importance_bar(df_imp, title, xlabel, out_path, top_n=15):\n",
    "    plot_df = df_imp.head(top_n).iloc[::-1]\n",
    "    fig, ax = plt.subplots(figsize=(10, 7))\n",
    "    ax.barh(plot_df[\"feature\"], plot_df[\"importance\"])\n",
    "    ax.set_title(title)\n",
    "    ax.set_xlabel(xlabel)\n",
    "    ax.grid(axis=\"x\", alpha=0.2)\n",
    "    plt.tight_layout()\n",
    "    plt.savefig(out_path, dpi=300, bbox_inches=\"tight\")\n",
    "    plt.close()\n",
    "\n",
    "\n",
    "def plot_permutation_boxplot(perm_result, feature_names, title, out_path, top_n=15):\n",
    "    sorted_idx = np.argsort(perm_result.importances_mean)[-top_n:]\n",
    "    fig, ax = plt.subplots(figsize=(10, 7))\n",
    "    ax.boxplot(\n",
    "        perm_result.importances[sorted_idx].T,\n",
    "        vert=False,\n",
    "        tick_labels=np.array(feature_names)[sorted_idx],\n",
    "    )\n",
    "    ax.set_title(title)\n",
    "    ax.set_xlabel(\"Decrease in ROC AUC\")\n",
    "    plt.tight_layout()\n",
    "    plt.savefig(out_path, dpi=300, bbox_inches=\"tight\")\n",
    "    plt.close()\n",
    "\n",
    "\n",
    "def run_model_workflow(\n",
    "    X_train: pd.DataFrame,\n",
    "    y_train: pd.Series,\n",
    "    X_test: pd.DataFrame,\n",
    "    y_test: pd.Series,\n",
    "    feature_set_name: str,\n",
    "    feature_set_description: str,\n",
    "    out_dir: Path,\n",
    "):\n",
    "    \"\"\"\n",
    "    Run:\n",
    "      - Random Forest\n",
    "      - XGBoost\n",
    "      - evaluation\n",
    "      - feature importance\n",
    "    \"\"\"\n",
    "    feature_out_dir = out_dir / feature_set_name\n",
    "    feature_out_dir.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "    with open(feature_out_dir / \"feature_set_description.txt\", \"w\", encoding=\"utf-8\") as f:\n",
    "        f.write(feature_set_description)\n",
    "\n",
    "    # Preprocessor uses train schema\n",
    "    X_train2, preprocessor, numeric_cols, categorical_cols = make_preprocessor(X_train)\n",
    "    X_test2, _, _, _ = make_preprocessor(X_test)\n",
    "\n",
    "    # -----------------------------------------------------\n",
    "    # Random Forest\n",
    "    # -----------------------------------------------------\n",
    "    rf_pipe = Pipeline(\n",
    "        steps=[\n",
    "            (\"preprocessor\", preprocessor),\n",
    "            (\"model\", RandomForestClassifier(\n",
    "                random_state=RANDOM_STATE,\n",
    "                class_weight=\"balanced\",\n",
    "                n_jobs=N_JOBS,\n",
    "            )),\n",
    "        ]\n",
    "    )\n",
    "\n",
    "    rf_param_grid = {\n",
    "        \"model__n_estimators\": [300],\n",
    "        \"model__max_depth\": [None, 8, 16],\n",
    "        \"model__min_samples_split\": [2, 10],\n",
    "        \"model__min_samples_leaf\": [1, 5],\n",
    "        \"model__max_features\": [\"sqrt\", 0.5],\n",
    "    }\n",
    "\n",
    "    rf_grid = GridSearchCV(\n",
    "        estimator=rf_pipe,\n",
    "        param_grid=rf_param_grid,\n",
    "        scoring=\"roc_auc\",\n",
    "        cv=5,\n",
    "        n_jobs=N_JOBS,\n",
    "        refit=True,\n",
    "        verbose=1,\n",
    "    )\n",
    "\n",
    "    rf_grid.fit(X_train2, y_train)\n",
    "    rf_best = rf_grid.best_estimator_\n",
    "    rf_metrics = evaluate_classifier(rf_best, X_test2, y_test)\n",
    "\n",
    "    pd.DataFrame([{\n",
    "        \"model\": \"Random Forest\",\n",
    "        \"feature_set\": feature_set_name,\n",
    "        \"feature_set_description\": feature_set_description,\n",
    "        \"best_cv_auc\": rf_grid.best_score_,\n",
    "        **rf_grid.best_params_,\n",
    "        \"test_auc\": rf_metrics[\"auc\"],\n",
    "        \"test_accuracy\": rf_metrics[\"accuracy\"],\n",
    "        \"test_precision\": rf_metrics[\"precision\"],\n",
    "        \"test_recall\": rf_metrics[\"recall\"],\n",
    "        \"test_f1\": rf_metrics[\"f1\"],\n",
    "    }]).to_csv(feature_out_dir / \"random_forest_metrics.csv\", index=False)\n",
    "\n",
    "    with open(feature_out_dir / \"random_forest_best_params.json\", \"w\") as f:\n",
    "        json.dump(rf_grid.best_params_, f, indent=2)\n",
    "\n",
    "    plot_confusion_matrix(\n",
    "        y_test,\n",
    "        rf_metrics[\"y_pred\"],\n",
    "        f\"Random Forest - Confusion Matrix ({feature_set_name})\",\n",
    "        feature_out_dir / \"random_forest_confusion_matrix.png\",\n",
    "    )\n",
    "\n",
    "    rf_feature_names = get_feature_names_from_pipeline(rf_best, numeric_cols, categorical_cols)\n",
    "    rf_native_importance = pd.DataFrame({\n",
    "        \"feature\": rf_feature_names,\n",
    "        \"importance\": rf_best.named_steps[\"model\"].feature_importances_,\n",
    "    }).sort_values(\"importance\", ascending=False).reset_index(drop=True)\n",
    "\n",
    "    rf_native_importance.to_csv(feature_out_dir / \"random_forest_native_importance.csv\", index=False)\n",
    "\n",
    "    plot_top_importance_bar(\n",
    "        rf_native_importance,\n",
    "        f\"Random Forest - Native Importance ({feature_set_name}, Top 15)\",\n",
    "        \"Importance\",\n",
    "        feature_out_dir / \"random_forest_native_importance_top15.png\",\n",
    "        top_n=15,\n",
    "    )\n",
    "\n",
    "    rf_perm_result = permutation_importance(\n",
    "        estimator=rf_best,\n",
    "        X=X_test2,\n",
    "        y=y_test,\n",
    "        scoring=\"roc_auc\",\n",
    "        n_repeats=20,\n",
    "        random_state=RANDOM_STATE,\n",
    "        n_jobs=N_JOBS,\n",
    "    )\n",
    "\n",
    "    rf_perm_importance = pd.DataFrame({\n",
    "        \"feature\": rf_feature_names,\n",
    "        \"importance_mean\": rf_perm_result.importances_mean,\n",
    "        \"importance_std\": rf_perm_result.importances_std,\n",
    "    }).sort_values(\"importance_mean\", ascending=False).reset_index(drop=True)\n",
    "\n",
    "    rf_perm_importance.to_csv(feature_out_dir / \"random_forest_permutation_importance.csv\", index=False)\n",
    "\n",
    "    plot_permutation_boxplot(\n",
    "        rf_perm_result,\n",
    "        rf_feature_names,\n",
    "        f\"Random Forest - Permutation Importance ({feature_set_name}, Top 15)\",\n",
    "        feature_out_dir / \"random_forest_permutation_importance_top15.png\",\n",
    "        top_n=15,\n",
    "    )\n",
    "\n",
    "    # -----------------------------------------------------\n",
    "    # XGBoost\n",
    "    # -----------------------------------------------------\n",
    "    xgb_pipe = Pipeline(\n",
    "        steps=[\n",
    "            (\"preprocessor\", preprocessor),\n",
    "            (\"model\", XGBClassifier(\n",
    "                objective=\"binary:logistic\",\n",
    "                eval_metric=\"auc\",\n",
    "                random_state=RANDOM_STATE,\n",
    "                n_estimators=300,\n",
    "                tree_method=\"hist\",\n",
    "                n_jobs=N_JOBS,\n",
    "            )),\n",
    "        ]\n",
    "    )\n",
    "\n",
    "    xgb_param_grid = {\n",
    "        \"model__max_depth\": [3, 6, 10],\n",
    "        \"model__learning_rate\": [0.03, 0.1],\n",
    "        \"model__subsample\": [0.8, 1.0],\n",
    "        \"model__colsample_bytree\": [0.8, 1.0],\n",
    "        \"model__min_child_weight\": [1, 5],\n",
    "    }\n",
    "\n",
    "    xgb_grid = GridSearchCV(\n",
    "        estimator=xgb_pipe,\n",
    "        param_grid=xgb_param_grid,\n",
    "        scoring=\"roc_auc\",\n",
    "        cv=5,\n",
    "        n_jobs=N_JOBS,\n",
    "        refit=True,\n",
    "        verbose=1,\n",
    "    )\n",
    "\n",
    "    xgb_grid.fit(X_train2, y_train)\n",
    "    xgb_best = xgb_grid.best_estimator_\n",
    "    xgb_metrics = evaluate_classifier(xgb_best, X_test2, y_test)\n",
    "\n",
    "    pd.DataFrame([{\n",
    "        \"model\": \"XGBoost\",\n",
    "        \"feature_set\": feature_set_name,\n",
    "        \"feature_set_description\": feature_set_description,\n",
    "        \"best_cv_auc\": xgb_grid.best_score_,\n",
    "        **xgb_grid.best_params_,\n",
    "        \"test_auc\": xgb_metrics[\"auc\"],\n",
    "        \"test_accuracy\": xgb_metrics[\"accuracy\"],\n",
    "        \"test_precision\": xgb_metrics[\"precision\"],\n",
