# -------------------------------------------------
# Category mapping (template + read assigned categories)
# -------------------------------------------------

category_map_path <- file.path(out_dir, "variable_category.csv")

# Create a template only if the category file does not exist yet
if (!file.exists(category_map_path)) {
  variable_category_template <- tibble(
    variable = names(ukb_no_id),
    category = ""
  )
  
  write_csv(variable_category_template, category_map_path)
  message("Category template created at: ", category_map_path)
  message("Fill in the 'category' column, save, then re-run the script.")
}

# Read category map (after you filled it in)
variable_category <- read_csv(category_map_path, show_col_types = FALSE) %>%
  mutate(
    variable = as.character(variable),
    category = as.character(category)
  )

# ---- Validation checks ----

# 1) Any variables in data that are missing from the mapping file?
missing_in_map <- setdiff(names(ukb_no_id), variable_category$variable)
if (length(missing_in_map) > 0) {
  stop(
    "These dataset variables are missing from variable_category.csv:\n",
    paste(missing_in_map, collapse = ", ")
  )
}

# 2) Any extra variables in mapping file not in dataset?
extra_in_map <- setdiff(variable_category$variable, names(ukb_no_id))
if (length(extra_in_map) > 0) {
  stop(
    "These variables are in variable_category.csv but not in the dataset:\n",
    paste(extra_in_map, collapse = ", ")
  )
}

# 3) Any unassigned categories?
unassigned <- variable_category %>%
  filter(is.na(category) | str_trim(category) == "")
if (nrow(unassigned) > 0) {
  stop(
    "Some variables have blank categories in variable_category.csv. Examples:\n",
    paste(head(unassigned$variable, 20), collapse = ", ")
  )
}

# 4) Standardise category labels (optional but recommended)
variable_category <- variable_category %>%
  mutate(category = str_to_lower(str_trim(category)))

# ============================================================
# Missingness by category
# ============================================================

missing_by_category <- missing_col %>%
  left_join(variable_category, by = "variable") %>%
  group_by(category) %>%
  summarise(
    n_vars = n(),
    mean_missing = mean(pct_missing, na.rm = TRUE),
    median_missing = median(pct_missing, na.rm = TRUE),
    n_vars_over_20 = sum(pct_missing > 20, na.rm = TRUE),
    .groups = "drop"
  ) %>%
  arrange(desc(mean_missing))

write_csv(missing_by_category,
          file.path(out_dir, "missingness_by_category.csv"))

p_cat <- ggplot(missing_by_category,
                aes(x = reorder(category, mean_missing),
                    y = mean_missing)) +
  geom_col() +
  coord_flip() +
  theme_classic(base_size = 12) +
  labs(
    title = "Mean missingness by category",
    x = NULL,
    y = "Mean percent missing"
  )

save_plot(p_cat, "fig_missingness_by_category.png")





