rm(list = ls())

# =========================================================
# 11) RANDOM-FOREST IMPUTATION (PARALLEL) USING futuremice + mice
# =========================================================

library(here)
library(dplyr)
library(mice)
library(future)
library(futuremice)
library(lubridate)

# -----------------------------
# 0) Parallel setup
# -----------------------------
n_cores <- future::availableCores()

# On HPC (Linux), multisession is robust; adjust if your cluster policy prefers multicore.
future::plan(multisession, workers = n_cores)

# -----------------------------
# 1) Load final cleaned dataset
# -----------------------------
ukb <- readRDS(here("00_data", "01_processed", "ukb_final_cleaned.rds"))

# Ensure eid exists and is NOT imputed
if (!("eid" %in% names(ukb))) stop("eid column not found in ukb_final_cleaned.rds")

# -----------------------------
# 2) Type handling before mice
#    - Convert character -> factor (mice rf expects categorical as factor)
#    - Convert Date -> numeric (days) for imputation, then convert back
# -----------------------------
date_cols <- names(ukb)[vapply(ukb, inherits, logical(1), what = "Date")]

ukb_pre <- ukb %>%
  mutate(across(where(is.character), as.factor)) %>%
  mutate(across(all_of(date_cols), ~ as.numeric(.)))  # Date -> days since origin

# -----------------------------
# 3) Define imputation methods and predictor matrix
# -----------------------------
meth <- make.method(ukb_pre)
pred <- make.predictorMatrix(ukb_pre)

# Do not impute eid; also do not use eid to predict others (identifier)
meth["eid"] <- ""
pred["eid", ] <- 0
pred[, "eid"] <- 0

# Random forest imputation for all other columns
# (mice will handle factors/numerics accordingly via method = "rf")
meth[meth != ""] <- "rf"

# -----------------------------
# 4) Run parallel RF imputation
# -----------------------------
set.seed(1)

imp <- futuremice(
  data = ukb_pre,
  m = 5,           # number of imputed datasets
  maxit = 5,       # iterations
  method = meth,
  predictorMatrix = pred,
  printFlag = TRUE
)

# Save the full mids object (contains all m imputations)
saveRDS(imp, here("00_data", "01_processed", "ukb_imputed_mids_rf.rds"))

# -----------------------------
# 5) Export one completed dataset (action = 1) and restore Date columns
# -----------------------------
ukb_imputed <- complete(imp, action = 1)

# Convert imputed numeric date columns back to Date (days since origin)
# as.Date(<numeric>, origin="1970-01-01") matches as.numeric(Date) encoding
if (length(date_cols) > 0) {
  ukb_imputed <- ukb_imputed %>%
    mutate(across(all_of(date_cols), ~ as.Date(.x, origin = "1970-01-01")))
}

saveRDS(ukb_imputed, here("00_data", "01_processed", "ukb_final_imputed_rf.rds"))

# Optional quick check: confirm no NA remains except in eid (should have none there either)
na_counts <- colSums(is.na(ukb_imputed))
print(na_counts[na_counts > 0])

