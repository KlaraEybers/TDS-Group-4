library(here)
library(dplyr)
library(mice)
library(future)
library(futuremice)

# -----------------------------
# 0) Parallel setup
# -----------------------------
n_cores <- future::availableCores()
future::plan(multisession, workers = n_cores)

# -----------------------------
# 1) Load final cleaned dataset
# -----------------------------
ukb <- readRDS(here("00_data", "01_processed", "ukb_final_cleaned.rds"))
if (!("eid" %in% names(ukb))) stop("eid column not found")

# -----------------------------
# 2) Type handling for mice
# -----------------------------
date_cols <- names(ukb)[vapply(ukb, inherits, logical(1), what = "Date")]

ukb_pre <- ukb %>%
  mutate(across(where(is.character), as.factor)) %>%
  mutate(across(all_of(date_cols), ~ as.numeric(.)))  # Date -> numeric days

# -----------------------------
# 3) Regression-based imputation against all other variables
#    Numeric: norm.predict (deterministic linear regression prediction)
#    Binary factor: logreg
#    >2-level unordered factor: polyreg
#    Ordered factor: polr
# -----------------------------
meth <- make.method(ukb_pre)
pred <- make.predictorMatrix(ukb_pre)

# Do not impute eid; do not use eid as predictor
meth["eid"] <- ""
pred["eid", ] <- 0
pred[, "eid"] <- 0

for (nm in names(ukb_pre)) {
  if (nm == "eid") next
  x <- ukb_pre[[nm]]
  
  if (is.numeric(x) || is.integer(x)) {
    meth[nm] <- "norm.predict"
  } else if (is.factor(x) || is.ordered(x)) {
    lv <- nlevels(x)
    if (is.ordered(x)) {
      meth[nm] <- "polr"
    } else if (lv == 2) {
      meth[nm] <- "logreg"
    } else if (lv > 2) {
      meth[nm] <- "polyreg"
    } else {
      meth[nm] <- ""  # degenerate factor
    }
  } else {
    meth[nm] <- ""    # unsupported type
  }
}

# -----------------------------
# 4) Run parallel mice
# -----------------------------
set.seed(1)

imp <- futuremice(
  data = ukb_pre,
  m = 5,
  maxit = 5,
  method = meth,
  predictorMatrix = pred,
  printFlag = TRUE
)

saveRDS(imp, here("00_data", "01_processed", "ukb_imputed_mids_regression.rds"))

ukb_imputed <- complete(imp, action = 1)

# Restore Date columns
if (length(date_cols) > 0) {
  ukb_imputed <- ukb_imputed %>%
    mutate(across(all_of(date_cols), ~ as.Date(.x, origin = "1970-01-01")))
}

saveRDS(ukb_imputed, here("00_data", "01_processed", "ukb_final_imputed_regression.rds"))

na_counts <- colSums(is.na(ukb_imputed))
print(na_counts[na_counts > 0])