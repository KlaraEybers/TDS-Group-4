library(here)
library(dplyr)
library(future)

# -----------------------------
# 0) Parallel setup (not required for mean, kept for consistency)
# -----------------------------
n_cores <- future::availableCores()
future::plan(multisession, workers = n_cores)

# -----------------------------
# 1) Load final cleaned dataset
# -----------------------------
ukb <- readRDS(here("00_data", "01_processed", "ukb_final_cleaned.rds"))
if (!("eid" %in% names(ukb))) stop("eid column not found")

# -----------------------------
# 2) Identify Date columns (restore later)
# -----------------------------
date_cols <- names(ukb)[vapply(ukb, inherits, logical(1), what = "Date")]

ukb2 <- ukb %>%
  mutate(across(where(is.character), as.factor)) %>%
  mutate(across(all_of(date_cols), ~ as.numeric(.)))  # Date -> numeric days

# -----------------------------
# 3) Mean (numeric) + mode (factor/ordered) imputation
# -----------------------------
mode_value <- function(x) {
  x2 <- x[!is.na(x)]
  if (length(x2) == 0) return(NA)
  tab <- table(x2)
  names(tab)[which.max(tab)]
}

for (nm in names(ukb2)) {
  if (nm == "eid") next
  
  x <- ukb2[[nm]]
  
  if (is.numeric(x) || is.integer(x)) {
    m <- mean(x, na.rm = TRUE)
    if (is.nan(m)) next
    x[is.na(x)] <- m
    ukb2[[nm]] <- x
  } else if (is.factor(x) || is.ordered(x)) {
    mv <- mode_value(x)
    if (is.na(mv)) next
    x[is.na(x)] <- mv
    ukb2[[nm]] <- droplevels(x)
  }
}

# Restore Date columns
if (length(date_cols) > 0) {
  ukb2 <- ukb2 %>%
    mutate(across(all_of(date_cols), ~ as.Date(.x, origin = "1970-01-01")))
}

saveRDS(ukb2, here("00_data", "01_processed", "ukb_final_imputed_mean_mode.rds"))

na_counts <- colSums(is.na(ukb2))
print(na_counts[na_counts > 0])

