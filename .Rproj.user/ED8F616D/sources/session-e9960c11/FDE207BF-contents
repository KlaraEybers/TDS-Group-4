sample_rows <- sample(seq_len(n_total), min(200, n_total))
sample_cols <- sample(names(ukb_no_id), min(50, n_vars))

heat_df <- ukb_no_id[sample_rows, sample_cols] %>%
  mutate(across(everything(), ~ is.na(.x))) %>%
  mutate(row_id = row_number()) %>%
  pivot_longer(
    cols = -row_id,
    names_to = "variable",
    values_to = "is_missing"
  )

p_heat <- ggplot(heat_df,
                 aes(x = variable,
                     y = row_id,
                     fill = is_missing)) +
  geom_tile() +
  theme_classic(base_size = 10) +
  theme(
    axis.text.x = element_text(angle = 90, hjust = 1),
    axis.title = element_blank()
  ) +
  labs(title = "Missingness heatmap (sample)",
       fill = "Missing")

save_plot(p_heat, "fig_missingness_heatmap.png", w = 10, h = 6)


