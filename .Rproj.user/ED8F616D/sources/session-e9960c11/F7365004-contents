# ================================
# 5) CORRELATION STRUCTURE (NUMERIC VARIABLES) - FIXED
# ================================

# Identify which base variables are numeric according to annot.csv
numeric_vars <- annot %>%
  filter(ValueType %in% c("Continuous", "Integer")) %>%
  pull(CodingName) %>%
  tolower()

# Map dataset columns to base variable names (strip ".i.j" suffix)
base_names <- names(ukb) %>%
  str_replace("\\.[0-9]+\\.[0-9]+$", "") %>%
  tolower()

# Keep columns whose base name is in numeric_vars
numeric_cols <- names(ukb)[base_names %in% numeric_vars]

# Subset numeric columns
numeric_df_raw <- ukb[, numeric_cols, drop = FALSE]

# Force everything to numeric (handles character/factor columns)
# Non-convertible entries become NA (expected if there are non-numeric strings)
numeric_df <- numeric_df_raw %>%
  mutate(across(everything(), ~ suppressWarnings(as.numeric(as.character(.)))))

# Drop columns that are completely NA after coercion (cannot be used in cor)
numeric_df <- numeric_df %>%
  select(where(~ any(!is.na(.))))

# Safety checks
if (ncol(numeric_df) < 2) {
  stop("After coercion to numeric, fewer than 2 usable numeric variables remain for correlation.")
}

# Correlation matrix (pairwise complete observations handles missingness)
cor_matrix <- cor(numeric_df, use = "pairwise.complete.obs")

write.csv(cor_matrix, "correlation_matrix.csv", row.names = TRUE)

# ================================
# 6) HIGH CORRELATION PAIRS (>|0.8|)
# ================================

cutoff <- 0.8

# Remove self-correlations
diag(cor_matrix) <- NA

# Identify high correlations (upper triangle only to avoid duplicates)
idx <- which(abs(cor_matrix) >= cutoff &
               upper.tri(cor_matrix),
             arr.ind = TRUE)

high_corr <- tibble(
  var1 = colnames(cor_matrix)[idx[,1]],
  var2 = colnames(cor_matrix)[idx[,2]],
  corr = cor_matrix[idx]
) %>%
  arrange(desc(abs(corr)))

write.csv(high_corr,
          "high_correlation_pairs.csv",
          row.names = FALSE)

