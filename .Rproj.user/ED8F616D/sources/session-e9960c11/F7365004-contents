library(tidyverse)

# 1) Read the full 600,000-row dataset
ukb_full <- readRDS("extraction_and_recoding/outputs/ukb_recoded.rds")

# 2) Keep only the first 10,000 participants (rows)
ukb_10k <- ukb_full[1:10000, , drop = FALSE]

# 3) Save the 10,000-row version
saveRDS(ukb_10k, "extraction_and_recoding/outputs/ukb_recoded_10k.rds")

# More info about columns
annot <- readRDS("extraction_and_recoding/outputs/annot.rds")

# -----------------------------
# 1) Read + clean CVD events
# -----------------------------
cvd_events <- readRDS("cvd_events.rds")  # EDIT path

cvd_cleaned <- cvd_events %>%
  mutate(date = as.Date(date)) %>%
  group_by(eid) %>%
  arrange(date) %>%
  slice(1) %>%                      # keep earliest CVD event per participant
  ungroup() %>%
  rename(first_cvd_date = date) %>%
  select(eid, first_cvd_date)

# -----------------------------
# 2) Read ukb_recoded + ensure eid column exists
# -----------------------------
ukb <- readRDS("ukb_recoded.rds")       # EDIT path

if (!("eid" %in% names(ukb))) {
  ukb <- ukb %>% rownames_to_column("eid")
}

# -----------------------------
# 3) Merge + add has_cvd indicator
# -----------------------------
ukb <- ukb %>%
  left_join(cvd_cleaned, by = "eid") %>%
  mutate(has_cvd = ifelse(!is.na(first_cvd_date), 1, 0))

# -----------------------------
# 4) Optional: drop participants whose first CVD occurred before baseline date
#    (only runs if a baseline date column exists)
# -----------------------------
baseline_date_col <- intersect(
  c("date_of_attending_assessment_centre", "recruitment_date", "assessment_date"),
  names(ukb)
)[1]

if (!is.na(baseline_date_col)) {
  ukb <- ukb %>%
    mutate("{baseline_date_col}" := as.Date(.data[[baseline_date_col]])) %>%
    filter(is.na(first_cvd_date) | first_cvd_date >= .data[[baseline_date_col]])
}

# ukb now contains: eid, first_cvd_date, has_cvd (plus all original variables)

